          <td style="color:#888;font-size:0.8rem">Star segments skip final decodeURIComponent — %2F preserved</td>
        </tr>
        <tr>
          <td style="color:#4a4"><code>window.location.pathname</code></td>
          <td style="padding:0.5rem"><a href="/encoding-test/hello%2Fworld" style="color:#4a4">/encoding-test/hello%2Fworld</a></td>
          <td style="color:#888;font-size:0.8rem">Raw browser value — bypasses route-recognizer</td>
        </tr>
        <tr>
          <td style="color:#4a4"><code>%252f</code> (double-encode)</td>
          <td style="padding:0.5rem"><a href="/users/..%252Fadmin" style="color:#4a4">/users/..%252Fadmin</a></td>
          <td style="color:#888;font-size:0.8rem">normalizePath re-encodes % — blocks double-decode attack</td>
        </tr>
      </tbody>
    </table>
