          <td style="padding:0.5rem"><a href="/users/..%2Fadmin" style="color:#f44">/users/..%2Fadmin</a></td>
          <td style="color:#888;font-size:0.8rem">findHandler() decodes %2F to / — CSPT via fetch</td>
        </tr>
        <tr>
          <td style="color:#f44"><code>params.widget</code><br/><span style="font-size:0.75rem;color:#888">(query param)</span></td>
          <td style="padding:0.5rem"><a href="/dashboard/stats?widget=../../attachments/malicious" style="color:#f44">/dashboard/stats?widget=../../attachments/malicious</a></td>
          <td style="color:#888;font-size:0.8rem">CSPT + triple curlies = XSS chain (CRITICAL)</td>
        </tr>
        <tr>
          <td style="color:#f44"><code>location.hash</code></td>
          <td style="padding:0.5rem"><a href="/dashboard/settings#../../admin/users" style="color:#f44">/dashboard/settings#../../admin/users</a></td>
          <td style="color:#888;font-size:0.8rem">Literal ../ in hash flows to fetch — never encoded</td>
        </tr>
        {{!-- double-encode moved to SAFE section --}}
        <tr>
          <td style="color:#f44"><code>params.category</code><br/><code>params.productId</code></td>
          <td style="padding:0.5rem"><a href="/shop/..%2Fadmin/99" style="color:#f44">/shop/..%2Fadmin/99</a></td>
          <td style="color:#888;font-size:0.8rem">Multi-param — both decoded independently</td>
        </tr>
        <tr>
          <td style="color:#f44"><code>params.teamId</code><br/><code>params.memberId</code></td>
          <td style="padding:0.5rem"><a href="/teams/..%2Fadmin/members/m1" style="color:#f44">/teams/..%2Fadmin/members/m1</a></td>
          <td style="color:#888;font-size:0.8rem">Nested params — each decoded via findHandler</td>
        </tr>
      </tbody>
    </table>
  </div>

  {{!-- SAFE / CONTRAST SOURCES --}}
  <div style="padding:1rem;background:#001a00;border-radius:8px;margin-bottom:2rem;border:1px solid #4a4">
    <h2 style="margin:0 0 0.75rem;color:#4a4">SAFE SOURCES (preserve %2F encoding)</h2>
    <p style="color:#888;font-size:0.85rem;margin:0 0 0.75rem">
