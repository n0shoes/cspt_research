  <div style="background:#1a1a1a;border:1px solid #333;border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.9rem;margin-bottom:8px">Ember-Specific Sinks</div>
    <table>
      <thead>
        <tr>
          <th>Sink</th>
