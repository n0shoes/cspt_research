        </tr>
        <tr>
          <td style="color:#f44">htmlSafe()</td>
          <td><code>htmlSafe(string)</code></td>
          <td>Marks string as safe for HTML rendering</td>
        </tr>
        <tr>
          <td style="color:#f44">Ember Data adapter</td>
          <td><code>urlForFindRecord(id)</code></td>
          <td>Interpolates id into fetch URL without encoding</td>
