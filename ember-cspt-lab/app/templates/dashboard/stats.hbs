<div style="padding:2rem;font-family:monospace;max-width:700px;background:#0d0d0d;min-height:100vh;color:#ccc">
  <a href="/" style="color:#888;font-size:0.85rem">← Back to index</a>
  <h1 style="color:#fff;margin:0.5rem 0 0.25rem">Query Param — CSPT + XSS Chain (CRITICAL)</h1>
  <p style="color:#888;margin-bottom:1.5rem">
    Source: <code>params.widget</code> (query param). Browser decodes %2F before Ember sees it.
    Combined with <code>&lbrace;&lbrace;&lbrace;content&rbrace;&rbrace;&rbrace;</code> (triple curlies), this is a CSPT-to-XSS chain.
    Try:
    <a href="/dashboard/stats?widget=../../attachments/malicious" style="color:#f44">
      ?widget=../../attachments/malicious
    </a>
  </p>

  {{!-- SOURCE --}}
  <div style="background:#1a1a1a;border:1px solid #333;border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">SOURCE</div>
    <code style="color:#f90">params.widget (query) → fetch(`/api/widgets/$&lbrace;widget&rbrace;`)</code><br/>
    <code style="color:#f90;font-size:0.85rem">→ response rendered via triple curlies (XSS sink)</code>
  </div>

  {{!-- RAW VALUE --}}
  <div style="background:#1a1a1a;border:1px solid {{if @model.hasDots '#f44' '#555'}};border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">RAW VALUE from params.widget</div>
    <code style="color:{{if @model.hasDots '#f44' '#ccc'}};font-size:1.1rem">
      widget = "{{@model.rawValue}}"
    </code>
    <div style="color:{{if @model.hasDots '#f44' '#888'}};font-size:0.8rem;margin-top:8px">
      {{#if @model.hasDots}}
        DANGEROUS: Query param decoded — traversal dots visible. Browser decoded this via standard URLSearchParams.
      {{else}}
        No traversal — add ?widget=../../attachments/malicious to test
      {{/if}}
    </div>
  </div>

  {{!-- FETCH URL --}}
  <div style="background:#1a1a1a;border:1px solid {{if @model.hasDots '#f44' '#555'}};border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">FETCH URL CONSTRUCTED</div>
    <code style="color:{{if @model.hasDots '#f44' '#ccc'}};font-size:1rem">{{@model.fetchUrl}}</code>
  </div>

  {{!-- SINK: Triple curlies --}}
  <div style="background:#1a1a1a;border:1px solid #f44;border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">SINK — triple curlies (XSS)</div>
    <div style="color:#f44;font-size:0.8rem;margin-bottom:8px">
      The raw HTML response from fetch is injected into the DOM via Ember's triple curlies.
      Triple curlies compile to <code>insertAdjacentHTML('beforeend', html)</code> — functionally identical to innerHTML.
    </div>
    {{!-- DANGEROUS SINK: triple curlies render raw HTML from API response --}}
    {{{@model.widgetHtml}}}
    {{#unless @model.widgetHtml}}
      <span style="color:#555">(no content loaded yet)</span>
    {{/unless}}
  </div>

  {{!-- RAW RESPONSE --}}
  <div style="background:#1a1a1a;border:1px solid #555;border-radius:6px;padding:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">RAW RESPONSE</div>
    <pre style="margin:0;color:#ccc;white-space:pre-wrap">{{@model.widgetHtml}}</pre>
  </div>
</div>
