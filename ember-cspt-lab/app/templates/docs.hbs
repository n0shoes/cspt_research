<div style="padding:2rem;font-family:monospace;max-width:700px;background:#0d0d0d;min-height:100vh;color:#ccc">
  <a href="/" style="color:#888;font-size:0.85rem">← Back to index</a>
  <h1 style="color:#fff;margin:0.5rem 0 0.25rem">params.doc_path — Wildcard *param</h1>
  <p style="color:#888;margin-bottom:1.5rem">
    Source: <code>params.doc_path</code> from <code>*doc_path</code> wildcard.
    Star segments use <code>(.+)</code> regex — captures everything including literal <code>/</code>.
    BUT: <code>findHandler()</code> <strong>SKIPS</strong> <code>decodeURIComponent</code> for star segments.
    So <code>%2F</code> stays encoded. Contrast with <a href="/users/..%2Fadmin" style="color:#f44">:param where %2F decodes</a>.
  </p>

  {{!-- SOURCE --}}
  <div style="background:#1a1a1a;border:1px solid #333;border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">SOURCE</div>
    <code style="color:#f90">// app/routes/docs.js model(params)</code><br/>
    <code style="color:#f90">params.doc_path → fetch(`/api/docs/$&lbrace;docPath&rbrace;`)</code><br/>
    <span style="color:#4a4;font-size:0.8rem">Star segment: shouldDecodes[j] = false → no final decodeURIComponent</span>
  </div>

  {{!-- RAW VALUE --}}
  <div style="background:#1a1a1a;border:1px solid {{if @model.hasEncodedSlash '#4a4' (if @model.hasDots '#f44' '#555')}};border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">RAW VALUE from params.doc_path</div>
    <code style="color:{{if @model.hasEncodedSlash '#4a4' (if @model.hasDots '#f44' '#ccc')}};font-size:1.1rem">
      doc_path = "{{@model.rawValue}}"
    </code>
    <div style="font-size:0.8rem;margin-top:8px">
      {{#if @model.hasEncodedSlash}}
        <span style="color:#4a4">SAFE: %2F preserved — star segments skip final decodeURIComponent. Compare with :param where %2F → /</span>
      {{else if @model.hasSlash}}
        <span style="color:#888">Contains literal / from URL path segments (wildcard captures across /)</span>
      {{else}}
        <span style="color:#888">Normal value — try /docs/..%2Fadmin to see encoding preserved</span>
      {{/if}}
    </div>
  </div>

  {{!-- FETCH URL --}}
  <div style="background:#1a1a1a;border:1px solid {{if @model.hasDots '#f44' '#555'}};border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">FETCH URL CONSTRUCTED</div>
    <code style="color:{{if @model.hasDots '#f44' '#ccc'}};font-size:1rem">
      {{@model.fetchUrl}}
    </code>
  </div>

  {{!-- KEY INSIGHT --}}
  <div style="background:#111;border:1px solid #f90;border-radius:6px;padding:1rem;margin-bottom:1rem">
    <div style="color:#f90;font-size:0.8rem;margin-bottom:4px">KEY INSIGHT: :param vs *param encoding</div>
    <table>
      <thead>
        <tr>
          <th>URL</th>
          <th>:param value</th>
          <th>*param value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td style="color:#ccc;font-size:0.85rem"><code>/x/..%2Fadmin</code></td>
          <td style="color:#f44;font-size:0.85rem"><code>../admin</code> (decoded!)</td>
          <td style="color:#4a4;font-size:0.85rem"><code>..%2Fadmin</code> (preserved)</td>
        </tr>
        <tr>
          <td style="color:#ccc;font-size:0.85rem"><code>/x/a/b/c</code></td>
          <td style="color:#888;font-size:0.85rem">No match (extra /)</td>
          <td style="color:#888;font-size:0.85rem"><code>a/b/c</code> (literal /)</td>
        </tr>
      </tbody>
    </table>
  </div>

  {{!-- RESULT --}}
  <div style="background:#1a1a1a;border:1px solid #555;border-radius:6px;padding:1rem">
    <div style="color:#888;font-size:0.8rem;margin-bottom:4px">RESULT from fetch</div>
    <pre style="margin:0;color:#ccc;white-space:pre-wrap">{{json @model.result}}</pre>
  </div>
</div>
