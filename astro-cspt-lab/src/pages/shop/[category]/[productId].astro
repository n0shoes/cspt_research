---
const { category, productId } = Astro.params;

// Both params use decodeURI() — %2F stays encoded in each segment
// But because there are TWO attacker-controlled segments, the attack surface is doubled
// Even without slash injection, you control the category and productId segments independently

const fetchUrl = `https://api.example.com/shop/${category}/products/${productId}`;

const categoryHasEncodedSlash = (category || '').includes('%2F') || (category || '').includes('%2f');
const productHasEncodedSlash = (productId || '').includes('%2F') || (productId || '').includes('%2f');
const categoryHasLiteral = (category || '').includes('/');
const productHasLiteral = (productId || '').includes('/');

let result: unknown = null;
let fetchError: string | null = null;
try {
  const res = await fetch(fetchUrl);
  result = await res.json().catch(() => ({ error: 'non-JSON response' }));
} catch (e) {
  fetchError = String(e);
}

const overallRisk = (categoryHasLiteral || productHasLiteral) ? '#f44'
  : (categoryHasEncodedSlash || productHasEncodedSlash) ? '#4a4'
  : '#f90';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Shop — Astro CSPT</title>
  </head>
  <body style="margin:0;padding:2rem;font-family:monospace;background:#0d0d0d;color:#ccc;max-width:700px;">

    <p style="color:#888;margin-bottom:0.5rem;"><a href="/" style="color:#888;">← index</a></p>
    <h1 style="color:#fff;">Multi-Param SSRF — Two Controlled Segments</h1>
    <p style="color:#888;margin-bottom:1.5rem;">
      Sources: <code>Astro.params.category</code> and <code>Astro.params.productId</code>.
      Both decoded via <code>decodeURI()</code> — <code>%2F</code> stays encoded in each.
      But with two controlled segments, attacker can manipulate the middle of the fetch URL.
    </p>

    <!-- BOX 1: SOURCE -->
    <div style="background:#1a1a1a;border:1px solid #333;border-radius:6px;padding:1rem;margin-bottom:1rem;">
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">SOURCE</div>
      <code style="color:#f90;">const &#123; category, productId &#125; = Astro.params;</code>
    </div>

    <!-- BOX 2: RAW VALUES -->
    <div style={`background:#1a1a1a;border:1px solid ${overallRisk};border-radius:6px;padding:1rem;margin-bottom:1rem;`}>
      <div style="color:#888;font-size:0.8rem;margin-bottom:8px;">RAW VALUES from Astro.params (after decodeURI)</div>

      <div style="margin-bottom:8px;">
        <span style="color:#888;font-size:0.75rem;">category:</span>
        <code style={`color:${categoryHasLiteral ? '#f44' : categoryHasEncodedSlash ? '#4a4' : '#ccc'};margin-left:8px;`}>
          {JSON.stringify(category)}
        </code>
        <span style={`color:${categoryHasLiteral ? '#f44' : categoryHasEncodedSlash ? '#4a4' : '#888'};font-size:0.75rem;margin-left:8px;`}>
          {categoryHasLiteral ? 'literal slash!' : categoryHasEncodedSlash ? '%2F preserved' : 'no slash'}
        </span>
      </div>

      <div>
        <span style="color:#888;font-size:0.75rem;">productId:</span>
        <code style={`color:${productHasLiteral ? '#f44' : productHasEncodedSlash ? '#4a4' : '#ccc'};margin-left:8px;`}>
          {JSON.stringify(productId)}
        </code>
        <span style={`color:${productHasLiteral ? '#f44' : productHasEncodedSlash ? '#4a4' : '#888'};font-size:0.75rem;margin-left:8px;`}>
          {productHasLiteral ? 'literal slash!' : productHasEncodedSlash ? '%2F preserved' : 'no slash'}
        </span>
      </div>

      <div style="color:#555;font-size:0.75rem;margin-top:8px;">
        pathname = {Astro.url.pathname}
      </div>
    </div>

    <!-- BOX 3: FETCH URL CONSTRUCTED -->
    <div style="background:#1a1a1a;border:1px solid #f90;border-radius:6px;padding:1rem;margin-bottom:1rem;">
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">FETCH URL CONSTRUCTED (server-side = SSRF)</div>
      <code style="color:#f90;font-size:1rem;word-break:break-all;">
        {fetchUrl}
      </code>
      <div style="color:#888;font-size:0.8rem;margin-top:6px;">
        Template: <code>`https://api.example.com/shop/$&#123;category&#125;/products/$&#123;productId&#125;`</code>
        <br/>
        Two attacker-controlled segments in the URL. Even without slash injection, segment content is attacker-controlled.
      </div>
    </div>

    <!-- BOX 4: RESULT -->
    <div style="background:#1a1a1a;border:1px solid #555;border-radius:6px;padding:1rem;">
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">RESULT</div>
      {fetchError
        ? <pre style="margin:0;color:#f44;">{fetchError}</pre>
        : <pre style="margin:0;color:#ccc;">{JSON.stringify(result, null, 2)}</pre>
      }
    </div>

    <div style="margin-top:1.5rem;padding:0.75rem;background:#111;border-radius:6px;border:1px solid #222;">
      <p style="margin:0;color:#888;font-size:0.8rem;">
        <strong style="color:#f90;">Test URLs:</strong>
        <br/>
        <a href="/shop/electronics/456" style="color:#ccc;">/shop/electronics/456</a> — normal
        <br/>
        <a href="/shop/electronics%2Fhacked/99" style="color:#4a4;">/shop/electronics%2Fhacked/99</a> — %2F stays in category
        <br/>
        <a href="/shop/../../admin/99" style="color:#f44;">/shop/../../admin/99</a> — literal traversal in category
      </p>
    </div>

  </body>
</html>
