---
const { path } = Astro.params;

// CRITICAL: catch-all [...path] param — slashes from URL path are LITERAL in the param
// This means /files/../../admin → path = "../../admin" with real slashes
// decodeURI() is still applied, but the slashes were never encoded to begin with
// Also: set:html is Astro's dangerouslySetInnerHTML — fetch response rendered as raw HTML

const fetchUrl = `https://internal-service.local/files/${path}`;

// Determine risk level
const hasLiteralSlash = (path || '').includes('/');
const hasDotDot = (path || '').includes('..');
const hasEncodedSlash = (path || '').includes('%2F') || (path || '').includes('%2f');

let content = '';
let fetchError: string | null = null;
try {
  const res = await fetch(fetchUrl);
  content = await res.text();
} catch (e) {
  fetchError = `[fetch failed: ${String(e)}]`;
  content = fetchError;
}

const riskColor = (hasLiteralSlash && hasDotDot) ? '#f44' : hasLiteralSlash ? '#f90' : '#4a4';
const riskLabel = (hasLiteralSlash && hasDotDot)
  ? 'CRITICAL: Literal ../ slashes in catch-all — direct path traversal possible in fetch URL'
  : hasLiteralSlash
  ? 'WARNING: Literal slashes in param — catch-all preserves URL slashes as-is'
  : 'No literal slashes detected — encoded slashes (%2F) would stay encoded via decodeURI()';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Files — Astro CSPT</title>
  </head>
  <body style="margin:0;padding:2rem;font-family:monospace;background:#0d0d0d;color:#ccc;max-width:700px;">

    <p style="color:#888;margin-bottom:0.5rem;"><a href="/" style="color:#888;">← index</a></p>
    <h1 style="color:#fff;">catch-all [...path] + set:html Sink</h1>
    <p style="color:#888;margin-bottom:1.5rem;">
      Source: <code>Astro.params.path</code> from <code>[...path]</code> catch-all.
      Literal URL slashes become literal slashes in the param (not encoded).
      <code>set:html</code> renders the fetch response as raw HTML — this is the XSS sink.
      Server-side fetch = SSRF. Combined = <strong style="color:#f44;">SSRF + XSS chain.</strong>
    </p>

    <!-- BOX 1: SOURCE -->
    <div style="background:#1a1a1a;border:1px solid #333;border-radius:6px;padding:1rem;margin-bottom:1rem;">
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">SOURCE</div>
      <code style="color:#f90;">const &#123; path &#125; = Astro.params; // [...path] catch-all</code>
      <div style="color:#888;font-size:0.75rem;margin-top:6px;">
        Catch-all params include literal slashes from the URL path.
        /files/a/b/c → path = "a/b/c" (real slashes, not encoded).
      </div>
    </div>

    <!-- BOX 2: RAW VALUE -->
    <div style={`background:#1a1a1a;border:1px solid ${riskColor};border-radius:6px;padding:1rem;margin-bottom:1rem;`}>
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">RAW VALUE from Astro.params (catch-all)</div>
      <code style={`color:${riskColor};font-size:1.1rem;`}>
        path = {JSON.stringify(path)}
      </code>
      <div style={`color:${riskColor};font-size:0.8rem;margin-top:6px;`}>
        {riskLabel}
      </div>
      <div style="color:#555;font-size:0.75rem;margin-top:4px;">
        pathname = {Astro.url.pathname}
      </div>
    </div>

    <!-- BOX 3: FETCH URL CONSTRUCTED -->
    <div style="background:#1a1a1a;border:1px solid #f44;border-radius:6px;padding:1rem;margin-bottom:1rem;">
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">FETCH URL CONSTRUCTED (server-side = SSRF)</div>
      <code style="color:#f44;font-size:1rem;word-break:break-all;">
        {fetchUrl}
      </code>
      <div style="color:#f44;font-size:0.8rem;margin-top:6px;">
        Literal slashes from catch-all param are injected directly into the URL.
        Path traversal: /files/../../admin → fetches internal-service.local/admin
      </div>
    </div>

    <!-- BOX 4: RESULT (via set:html — XSS SINK) -->
    <div style="background:#1a1a1a;border:1px solid #f44;border-radius:6px;padding:1rem;">
      <div style="color:#888;font-size:0.8rem;margin-bottom:4px;">RESULT <span style="color:#f44;">(rendered via set:html — XSS SINK)</span></div>
      <div style="color:#f44;font-size:0.75rem;margin-bottom:6px;">
        The content below is rendered as raw HTML with no sanitization.
        If the fetch response contains &lt;script&gt; tags, they execute.
      </div>
      <div set:html={content} style="color:#ccc;border:1px solid #333;padding:0.5rem;border-radius:4px;" />
    </div>

    <div style="margin-top:1.5rem;padding:0.75rem;background:#111;border-radius:6px;border:1px solid #222;">
      <p style="margin:0;color:#888;font-size:0.8rem;">
        <strong style="color:#f44;">Test URLs (SSRF + XSS chain):</strong>
        <br/>
        <a href="/files/docs/readme" style="color:#ccc;">/files/docs/readme</a> — normal path (path="docs/readme")
        <br/>
        <a href="/files/../../etc/passwd" style="color:#f44;">/files/../../etc/passwd</a> — literal traversal (path="../../etc/passwd")
        <br/>
        <a href="/files/docs%2Freadme" style="color:#4a4;">/files/docs%2Freadme</a> — %2F encoded (stays encoded, no traversal)
      </p>
    </div>

  </body>
</html>
